{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "[ -n \"$CMUX_SURFACE_ID\" ] && [ \"$CMUX_CODEX_HOOKS_DISABLED\" != \"1\" ] && command -v cmux >/dev/null 2>&1 && cmux hooks feed --source codex --event Notification || echo '{}'",
            "timeout": 120000,
            "type": "command"
          }
        ]
      }
    ],
